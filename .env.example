# Banco PostgreSQL (docker-compose usa estes valores por padrão)
DATABASE_URL=postgresql+asyncpg://cabecao:cabecao@localhost:5432/cabecao

# Opcional: agente conversacional (deixe vazio para só JSON/resumo sem LLM)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2

# API
API_HOST=127.0.0.1
API_PORT=8000
